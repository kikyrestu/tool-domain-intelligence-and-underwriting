# =============================================================
#  Domain IQ — Environment Variables Template
#  Salin file ini menjadi .env lalu isi sesuai lingkungan Anda.
#  Jangan pernah commit file .env ke Git / kirim ke siapapun.
# =============================================================


# -------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------
# Isi field di bawah sesuai setup database kamu.
# Untuk PostgreSQL LOKAL — DB_HOST=localhost, DB_SSL=false
# Untuk cloud (Neon, Supabase, dll) — DB_HOST=ep-xxx.aws.neon.tech, DB_SSL=true
DB_HOST=your_database_host
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SSL=false


# -------------------------------------------------------------
# AUTENTIKASI APLIKASI
# -------------------------------------------------------------
# Username dan password untuk login ke dashboard web.
# Ganti AUTH_PASSWORD sebelum digunakan di produksi!
AUTH_USERNAME=admin
AUTH_PASSWORD=GantiPasswordIni!

# Secret key untuk session/cookie — harus string acak yang panjang.
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-string-acak-panjang-32-karakter-atau-lebih


# -------------------------------------------------------------
# PROXY (opsional)
# -------------------------------------------------------------
# true  = gunakan proxy dari file PROXY_FILE saat crawling
# false = crawl langsung tanpa proxy
PROXY_ENABLED=false

# Path ke file daftar proxy (satu proxy per baris, format: http://ip:port)
PROXY_FILE=proxies.txt


# -------------------------------------------------------------
# KONFIGURASI SERVER (opsional — ada nilai default)
# -------------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000


# -------------------------------------------------------------
# RATE LIMITING (opsional — ada nilai default)
# -------------------------------------------------------------
# Jeda antar request crawl dalam detik (hindari ban IP)
CRAWL_DELAY_SECONDS=2.0
RDAP_DELAY_SECONDS=1.0
WAYBACK_DELAY_SECONDS=1.0


# -------------------------------------------------------------
# BATAS OPERASI (opsional — ada nilai default)
# -------------------------------------------------------------
MAX_CANDIDATES_PER_CRAWL=500
WAYBACK_SAMPLE_SIZE=5

# Seberapa sering (dalam jam) domain yang di-star dicek ulang RDAP-nya
# Default: setiap 6 jam. Set 24 untuk sekali sehari.
STARRED_RECHECK_HOURS=6

# -------------------------------------------------------------
# SCRAPING API PROVIDERS (opsional — isi minimal 1 provider)
# -------------------------------------------------------------
# Semua mendukung multi-key comma-separated (round-robin otomatis).
# Provider dirotasi berurutan: ZenRows → ScraperAPI → Scrapingbee → Crawlbase

# ZenRows — https://zenrows.com (free: 1.000 credits/bulan)
# Bisa multi-key: KEY1,KEY2,KEY3
ZENROWS_API_KEYS=your_zenrows_api_key

# ScraperAPI — https://scraperapi.com (free: 5.000 req/bulan)
SCRAPERAPI_KEYS=your_scraperapi_key

# Scrapingbee — https://scrapingbee.com
SCRAPINGBEE_KEYS=your_scrapingbee_key

# Crawlbase — https://crawlbase.com
# Normal token (halaman biasa, 1 credit)
CRAWLBASE_KEYS=your_crawlbase_normal_token
# JS token (halaman butuh JavaScript, 5 credits)
CRAWLBASE_JS_KEYS=your_crawlbase_js_token

# ScrapeGraphAI — https://scrapegraphai.com (AI-based, untuk extract link sulit)
SCRAPEGRAPHAI_KEY=your_scrapegraphai_key
